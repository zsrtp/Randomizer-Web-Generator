    },
    {
      // 2nd layer is "sometimes" hints
      "groupId": "overworld2nd",
      "hintDef": {
        "copies": 2,
        "hintDef": [
          {
            // TODO: change this to do the dungeon sometimes hint.
            "maxPicks": 5,
            "saveToVar": "2ndLayerSometimes",
            "hintDef": [
              {
                "maxPicks": 1,
                // Hint 1 dungeon sometimes. Hard-prioritizes PoT BK chest if
                // either PoT BK or not known barren from BeyondThisPoint hint.
                "hintDef": [
                  {
                    "hintType": "location",
                    "options": {
                      "markAsSometimes": true,
                      "validChecks": ["Palace of Twilight Big Key Chest"],
                      "validItems": ["Palace_of_Twilight_Big_Key"],
                      "allowKnownBarren": true
                    }
                  },
                  {
                    "hintType": "location",
                    "options": {
                      "markAsSometimes": true,
                      "validChecks": ["Palace of Twilight Big Key Chest"]
                    }
                  },
                  {
                    "hintType": "location",
                    "options": {
                      "markAsSometimes": true,
                      "validChecks": [
                        "Forest Temple Central North Chest",
                        "Goron Mines Main Magnet Room Top Chest",
                        "City in The Sky West Wing First Chest",
                        "City in The Sky Chest Behind North Fan",
                        // Include miniboss hints here for now. The guaranteed
                        // one seems too strong alongside the BTP hints maybe.
                        "Arbiters Grounds Death Sword Chest",
                        "City in The Sky Aeralfos Chest",
                        "Hyrule Castle King Bulblin Key"
                      ]
                    }
                  }
                ]
              },
              // {
              //   // Hint 1 dungeon miniboss
              //   "hintType": "location",
              //   "options": {
              //     "markAsSometimes": true,
              //     "validChecks": [
              //       "Arbiters Grounds Death Sword Chest",
              //       "City in The Sky Aeralfos Chest"
              //     ]
              //   }
              // },
              {
                "hintType": "sometimes",
                "iterations": 99,
                "options": {
                  "prioritizeNewZones": true
                }
              }
            ]
          },
          // Fill in layer with extra copies of the sometimes hints.
          {
            "hintType": "var",
            "copies": 1,
            "iterations": 99,
            "options": {
              "varName": "2ndLayerSometimes",
              "randomOrder": true
            }
