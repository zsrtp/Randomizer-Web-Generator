{
  // Season 2 placeholder distribution
  "starting": {
    "spot": "midna",
    "excludeFromGroups": true
  },
  "agitha": true,
  "jovani": {
    "minFoundSoulsForHint": 0,
    "maxFoundSoulsForVagueItem": 20
  },
  "caveOfOrdeals": true,
  "dungeons": {
    "bigKeyHints": true
  },
  "beyondPointZones": ["alias:all"],
  "barren": {
    "monopolizeSpots": true,
    "ownZoneShowsAsJunkHint": true
  },
  "always": {
    "monopolizeSpots": false,
    "idealNumSpots": 10,
    "copies": 2,
    "groupId": "overworld2nd"
  },
  //
  "addChecks": {
    // "Lake Hylia Shell Blade Grotto Chest": ["always"],
    "Skybook From Impaz": ["always"],
    "Hyrule Castle Graveyard Owl Statue Chest": ["always"],
    "Doctors Office Balcony Chest": ["sometimes"]
  },
  "removeChecks": {
    "Palace of Twilight Collect Both Sols": ["always"],
    "Herding Goats Reward": ["sometimes"],
    "Wrestling With Bo": ["sometimes"],
    "Zoras Domain Extinguish All Torches Chest": ["sometimes"],
    "Zoras Domain Light All Torches Chest": ["sometimes"],
    "Eldin Spring Underwater Chest": ["sometimes"],
    "Lake Hylia Underwater Chest": ["sometimes"],
    "Outside South Castle Town Tightrope Chest": ["sometimes"],
    "Gift From Ralis": ["sometimes"]
  },
  "removeItems": {
    "Progressive_Sword": ["sometimes"]
  },
  //
  "groups": {
    "overworld": [
      "alias:overworldZones",
      "-hiddenvillage",
      "-snowpeakmountain"
    ],
    "overworld2nd": [
      "alias:overworldZones",
      "-hiddenvillage",
      "-snowpeakmountain",
      "-ordon"
    ],
    "requiredDungeons": ["alias:requiredDungeons"],
    "hyruleCastle": ["hyrulecastle"]
  },
  // Special hints generated right after Always hints are generated. These are
  // created even if the dungeon is hinted barren or the check is already hinted
  // barren by a BeyondThisPoint hint.
  "specialHintDefs": [
    {
      "spot": "ordon_sign",
      "hintDef": [
        {
          "hintType": "location",
          "options": {
            "canBeClaimHinted": true,
            "validStatuses": ["bad"],
            "validChecks": ["Herding Goats Reward", "Wrestling With Bo"]
          }
        },
        {
          "hintType": "location",
          "options": {
            "canBeClaimHinted": true,
            "validChecks": ["Herding Goats Reward", "Wrestling With Bo"]
          }
        }
      ]
    },
    {
      "spot": "death_mountain_sign",
      "hintDef": {
        "hintType": "entrance",
        "options": {
          "validSourceZones": ["Goron Mines"]
        }
      }
    },
    {
      "spot": "snowpeak_mountain_sign",
      "hintDef": {
        "hintType": "entrance",
        "options": {
          "validSourceZones": ["Snowpeak Ruins"]
        }
      }
    },
    {
      "spot": "forest_temple_sign",
      "hintDef": {
        "hintType": "location",
        "options": {
          "canBeClaimHinted": true,
          "validChecks": ["Forest Temple Gale Boomerang"]
        }
      }
    },
    {
      "spot": "snowpeak_ruins_sign",
      "hintDef": {
        "maxPicks": 1,
        "hintDef": [
          {
            "hintType": "location",
            "options": {
              "canBeClaimHinted": true,
              "validChecks": [
                "Snowpeak Ruins Chapel Chest",
                "Snowpeak Ruins Lobby Chandelier Chest",
                "Snowpeak Ruins Northeast Chandelier Chest"
              ],
              "validItems": ["Snowpeak_Ruins_Bedroom_Key"]
            }
          },
          {
            "hintType": "location",
            "options": {
              "canBeClaimHinted": true,
              "validChecks": [
                "Snowpeak Ruins Chapel Chest",
                "Snowpeak Ruins Lobby Chandelier Chest",
                "Snowpeak Ruins Northeast Chandelier Chest"
              ]
            }
          }
        ]
      }
    },
    {
      "spot": "temple_of_time_sign",
      "hintDef": {
        "hintType": "location",
        "options": {
          "canBeClaimHinted": true,
          "validChecks": ["Temple of Time Darknut Chest"]
        }
      }
    },
    {
      "spot": "palace_of_twilight_sign",
      "hintDef": {
        "hintType": "location",
        "options": {
          "canBeClaimHinted": true,
          "validChecks": ["Palace of Twilight Collect Both Sols"]
        }
      }
    },
    {
      "spot": "hyrule_castle_sign",
      "hintDef": {
        "hintType": "location",
        "options": {
          "canBeClaimHinted": true,
          "validChecks": ["Hyrule Castle King Bulblin Key"]
        }
      }
    }
  ],
  "hints": [
    {
      "groupId": "overworld",
      "hintDef": {
        "copies": 2,
        "hintDef": [
          {
            "hintDef": [
              {
                "maxPicks": 3,
                "starting": 3,
                "hintDef": [
                  {
                    "hintType": "barren",
                    "options": {
                      "validAreas": [
                        "Ordon",
                        "Sacred Grove",
                        "Faron Field",
                        "Faron Woods",
                        "Kakariko Village",
                        "Kakariko Graveyard",
                        "Eldin Field",
                        "Castle Town",
                        "South of Castle Town",
                        "Lake Hylia",
                        "Zora's Domain",
                        "Upper Zora's River",
                        "Gerudo Desert",
                        "category.Northern_Desert",
                        "category.Southern_Desert",
                        "Bulblin Camp"
                      ]
                    }
                  },
                  {
                    "hintType": "barren",
                    "iterations": 3,
                    "saveToVar": "barrenHints",
                    "options": {
                      "validAreas": [
                        "alias:overworldZones",
                        "category.Northern_Desert",
                        "category.Southern_Desert"
                      ]
                    }
                  }
                ]
              }
            ]
          },
          // {
          //   "hintType": "item",
          //   "options": {
          //     "validItems": ["Boomerang"],
          //     "areaType": "zone",
          //     // Allowing bad in general and not just in hinted-barren zone as
          //     // seen below since that never lined up even after a large number
          //     // of seed attempts by testing with breakpoints. This hint can
          //     // help with rang in an IC-hinted dungeon as well which I did see
          //     // in a breakpoint.
          //     // "validChecks": ["var:barrenHints.areaIds"],
          //     "validStatuses": ["bad"],
          //     "allowKnownBarren": true
          //   }
          // },
          {
            "hintType": "entrance",
            "saveToVar": "hcEntranceHint",
            "copies": 3,
            "options": {
              "ignoreAlreadyHinted": true,
              "validDestinationZones": ["Hyrule Castle"]
            }
          },
          {
            // TODO: prefer importance counts 0,1,2
            "maxPicks": 1,
            "hintDef": [
              {
                "hintType": "importanceCount",
                "options": {
                  "indicateImportant": true,
                  "validAreas": [
                    "Forest Temple",
                    "Goron Mines",
                    "Lakebed Temple",
                    "Arbiter's Grounds",
                    "Snowpeak Ruins",
                    "Temple of Time",
                    "City in the Sky",
                    "Palace of Twilight",
                    "Hyrule Castle"
                  ]
                }
              }
            ]
          },
          {
            "hintType": "path",
            "iterations": 4,
            "options": {
              "invalidItems": ["Progressive_Sword"]
            }
          },
          {
            "hintType": "sometimes",
            "maxPicks": 2
            // "iterations": 99
          },
          // Fill in layer with extra copies of the HC entrance hint.
          {
            "hintType": "var",
            "copies": 1,
            "iterations": 99,
            "options": {
              "varName": "hcEntranceHint",
              "randomOrder": true
            }
          }
          // TODO: need to fall back to sometimes when hcEntranceHint not
          // generated due to no dungeon ER. Also EntranceHint should check if
          // any/which dungeon ER is enabled when determining what is possible
          // to hint if anything.
        ]
      }
    },
    {
      "groupId": "hyruleCastle",
      // For the HC sign, if possible place a Zant path hint. Otherwise simply
      // hint numClawshots in one of Faron, Eldin, and Lanayru (0 is valid).
      "hintDef": {
        "maxPicks": 1,
        "hintDef": [
          {
            "hintType": "path",
            "options": {
              "validGoals": ["Zant"]
            }
          },
          {
            "hintType": "numItemInArea",
            "options": {
              "item": "Progressive_Clawshot",
              "areaType": "province",
              "validAreas": ["Faron", "Eldin", "Lanayru"]
            }
          }
        ]
      }
    },
    {
      // On required dungeon signs, hint the number of swords in dungeons.
      "groupId": "requiredDungeons",
      "hintDef": {
        "hintType": "numItemInArea",
        "copies": 99,
        "minCopies": 1,
        "options": {
          "item": "Progressive_Sword",
          "areaType": "province",
          "validAreas": ["Dungeon"]
        }
      }
    },
    {
      // 2nd layer is "sometimes" hints
      "groupId": "overworld2nd",
      "hintDef": {
        "copies": 2,
        "hintDef": [
          {
            // TODO: change this to do the dungeon sometimes hint.
            "maxPicks": 5,
            "saveToVar": "2ndLayerSometimes",
            "hintDef": [
              {
                "hintType": "location",
                "options": {
                  "markAsSometimes": true,
                  "namedChecks": ["City in The Sky West Wing First Chest"],
                  "namedProbability": 0.5
                }
              },
              {
                "hintType": "sometimes",
                "iterations": 99
              }
            ]
          },
          // Fill in layer with extra copies of the sometimes hints.
          {
            "hintType": "var",
            "copies": 1,
            "iterations": 99,
            "options": {
              "varName": "2ndLayerSometimes",
              "randomOrder": true
            }
          }
        ]
      }
    }
  ]
}
