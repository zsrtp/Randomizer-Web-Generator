    {
      "groupId": "overworld",
      "hintDef": {
        "copies": 2,
        "hintDef": [
          {
            "hintDef": [
              {
                "maxPicks": 3,
                "starting": 3,
                "hintDef": [
                  {
                    // One barren for early game or desert area
                    "hintType": "barren",
                    "options": {
                      "validAreas": [
                        "Ordon",
                        // "Sacred Grove",
                        "Faron Field",
                        "Faron Woods",
                        "Kakariko Village",
                        "Kakariko Graveyard",
                        "Eldin Field",
                        "Castle Town",
                        "South of Castle Town",
                        "Lake Hylia",
                        "Zora's Domain",
                        "Upper Zora's River",
                        "Gerudo Desert",
                        "category.Northern_Desert",
                        "category.Southern_Desert",
                        "Bulblin Camp"
                      ]
                    }
                  },
                  {
                    "hintType": "barren",
                    "iterations": 3,
                    "saveToVar": "barrenHints",
                    "options": {
                      "validAreas": [
                        "alias:overworldZones",
                        "category.Northern_Desert",
                        "category.Southern_Desert"
                      ]
                    }
                  }
                ]
              }
            ]
          },
          // {
          //   "hintType": "entrance",
          //   "saveToVar": "hcEntranceHint",
          //   "copies": 3,
          //   "options": {
          //     "ignoreAlreadyHinted": true,
          //     "validDestinationZones": ["Hyrule Castle"]
          //   }
          // },
          {
            // Prioritizes hinting importance counts 0,1,2 (weighted equally)
            // for non-HC dungeon since already hinted on HC sign. Falls back to
            // any count, but for S2 this is basically guaranteed not to happen.
            "maxPicks": 1,
            "hintDef": [
              {
                "selectionType": "randomOrder",
                "hintDef": [
                  {
                    "hintType": "importanceCount",
                    "saveToVar": "icHint",
                    "options": {
                      "indicateImportant": true,
                      "allowedCounts": [0],
                      "validAreas": [
                        "Forest Temple",
                        "Goron Mines",
                        "Lakebed Temple",
                        "Arbiter's Grounds",
                        "Snowpeak Ruins",
                        "Temple of Time",
                        "City in the Sky",
                        "Palace of Twilight"
                      ]
                    }
                  },
                  {
                    "hintType": "importanceCount",
                    "saveToVar": "icHint",
                    "options": {
                      "indicateImportant": true,
                      "allowedCounts": [1],
                      "validAreas": [
                        "Forest Temple",
                        "Goron Mines",
                        "Lakebed Temple",
                        "Arbiter's Grounds",
                        "Snowpeak Ruins",
                        "Temple of Time",
                        "City in the Sky",
                        "Palace of Twilight"
                      ]
                    }
                  },
                  {
                    "hintType": "importanceCount",
                    "saveToVar": "icHint",
                    "options": {
                      "indicateImportant": true,
                      "allowedCounts": [2],
                      "validAreas": [
                        "Forest Temple",
                        "Goron Mines",
                        "Lakebed Temple",
                        "Arbiter's Grounds",
                        "Snowpeak Ruins",
                        "Temple of Time",
                        "City in the Sky",
                        "Palace of Twilight"
                      ]
                    }
                  }
                ]
              },
              {
                "hintType": "importanceCount",
                "options": {
                  "indicateImportant": true,
                  "validAreas": [
                    "Forest Temple",
                    "Goron Mines",
                    "Lakebed Temple",
                    "Arbiter's Grounds",
                    "Snowpeak Ruins",
                    "Temple of Time",
                    "City in the Sky",
                    "Palace of Twilight",
                    "Hyrule Castle"
                  ]
                }
              }
            ]
          },
          {
            "hintType": "path",
            "iterations": 4,
            "options": {
              "invalidItems": ["Progressive_Sword"]
            }
          },
          {
            "hintType": "sometimes",
            // "maxPicks": 2
            "iterations": 99,
            "options": {
              "prioritizeNewZones": true
            }
          },
          // Fill in layer with extra copies of the IC hint.
          {
            "hintType": "var",
            "copies": 1,
            "iterations": 99,
            "options": {
              "varName": "icHint",
              "randomOrder": true
            }
          }
          // Fill in layer with extra copies of the HC entrance hint.
          // {
          //   "hintType": "var",
          //   "copies": 1,
          //   "iterations": 99,
          //   "options": {
          //     "varName": "hcEntranceHint",
          //     "randomOrder": true
          //   }
          // }
          // TODO: need to fall back to sometimes when hcEntranceHint not
          // generated due to no dungeon ER. Also EntranceHint should check if
          // any/which dungeon ER is enabled when determining what is possible
          // to hint if anything.
        ]
      }
    },
    {
      "groupId": "palaceOfTwilight",
      "hintDef": {
        "hintType": "path",
        "options": {
          "invalidItems": ["Progressive_Sword"],
          "validGoals": ["Zant"]
        }
