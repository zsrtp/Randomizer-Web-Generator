    //     }
    //   }
    // }
    {
      "spot": "hyrule_castle_sign",
      "hintDef": {
        "hintType": "importanceCount",
        "options": {
          "indicateImportant": true,
          "validAreas": ["Hyrule Castle"]
        }
      }
    },
    {
      "spot": "hyrule_castle_sign",
      "hintDef": [
        // {
        //   "hintType": "path",
        //   "options": {
        //     "invalidItems": ["Progressive_Sword"],
        //     "validGoals": ["Zant"]
        //   }
        // },
        {
          "hintType": "item",
          "options": {
            "validItems": ["Boomerang"],
            "areaType": "zone",
            // Allowing bad in general and not just in hinted-barren zone as
            // seen below since that never lined up even after a large number
            // of seed attempts by testing with breakpoints. This hint can
            // help with rang in an IC-hinted dungeon as well which I did see
            // in a breakpoint.
            // "validChecks": ["var:barrenHints.areaIds"],
            "validStatuses": ["bad"],
            "allowKnownBarren": true
          }
        },
        {
          "hintType": "item",
          "options": {
            "validItems": ["Boomerang"],
            "areaType": "province",
            // "validStatuses": ["bad"],
            "allowKnownBarren": true
          }
        },
        {
          "hintType": "numItemInArea",
          "options": {
            "item": "Progressive_Clawshot",
            "areaType": "province",
            "validAreas": ["Faron", "Eldin", "Lanayru"]
          }
        }
      ]
    }
  ],
  "hints": [
