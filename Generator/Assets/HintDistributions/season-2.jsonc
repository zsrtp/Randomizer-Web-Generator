    {
      // 2nd layer is "sometimes" hints
      "groupId": "overworld2nd",
      "hintDef": {
        "copies": 2,
        "hintDef": [
          {
            "maxPicks": 5,
            "hintDef": [
              {
                // Hint 1 dungeon sometimes. Hard-prioritizes PoT BK chest if either
                // PoT BK or not known barren from BeyondThisPoint hint. Note: we
                // hint this before the Path hints so that HC King Bulblin does not
                // get claimed by a Path hint, meaning we should always have a valid
                // target for the sometimes.
                "hintDef": {
                  "hintType": "location",
                  "saveToVar": "2ndLayerSometimes",
                  "options": {
                    "markAsSometimes": true,
                    "validChecks": [
                      "Forest Temple Central North Chest",
                      // "Forest Temple West Tile Worm Chest Behind Stairs",
                      "Goron Mines Outside Clawshot Chest",
                      "Lakebed Temple Deku Toad Chest",
                      // "Goron Mines Main Magnet Room Top Chest",
                      "City in The Sky West Wing First Chest",
                      // "City in The Sky Chest Behind North Fan",
                      "Arbiters Grounds Death Sword Chest",
                      "City in The Sky Aeralfos Chest",
                      "Palace of Twilight Big Key Chest"
                    ]
                  }
                }
              },
              {
                "maxPicks": 1,
                "hintDef": [
                  {
                    "selectionType": "randomOrder",
                    "hintDef": [
                      {
                        "hintType": "location",
                        "saveToVar": "2ndLayerBoGoats",
                        "weight": 0.55,
                        "options": {
                          "validChecks": ["Wrestling With Bo"],
                          "validStatuses": ["bad"]
                        }
                      },
