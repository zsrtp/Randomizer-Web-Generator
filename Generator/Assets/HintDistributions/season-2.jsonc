                    "hintType": "importanceCount",
                    "saveToVar": "firstLayerSpotFiller",
                    "weight": 0.3,
                    "options": {
                      "indicateImportant": false,
                      "allowedCounts": [3],
                      "validAreas": [
                        "Sacred Grove",
                        "Kakariko Gorge",
                        "Kakariko Village",
                        "Kakariko Graveyard",
                        "Lanayru Field",
                        "Beside Castle Town",
                        "Great Bridge of Hylia",
                        "Lanayru Spring",
                        "Zora's Domain",
                        "Gerudo Desert",
                        "Hyrule Castle"
                      ]
                    }
                  }
                ]
              },
              {
                "hintType": "importanceCount",
                "saveToVar": "firstLayerSpotFiller",
                "options": {
                  "indicateImportant": false,
                  "validAreas": [
                    "Sacred Grove",
                    "Kakariko Gorge",
                    "Kakariko Village",
                    "Kakariko Graveyard",
