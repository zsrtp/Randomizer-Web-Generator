                    "selectionType": "randomOrder",
                    "hintDef": [
                      {
                        "hintType": "location",
                        "saveToVar": "2ndLayerBoGoats",
                        "weight": 0.55,
                        "options": {
                          "validChecks": ["Wrestling With Bo"]
                        }
                      },
                      {
                        "hintType": "location",
                        "saveToVar": "2ndLayerBoGoats",
                        "weight": 0.45,
                        "options": {
                          "validChecks": ["Herding Goats Reward"]
                        }
                      }
                    ]
                  }
                ]
              },
              {
                "hintType": "sometimes",
                "saveToVar": "2ndLayerSometimes",
                "iterations": 99,
                "options": {
                  "prioritizeNewZones": true
                }
              }
            ]
