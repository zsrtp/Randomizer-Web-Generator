  "caveOfOrdeals": true,
  "dungeons": {
    "bigKeyHints": true
  },
  "beyondPointZones": ["alias:dungeons", "Snowpeak_Mountain"],
  "barren": {
    "monopolizeSpots": true,
    "ownZoneShowsAsJunkHint": true
