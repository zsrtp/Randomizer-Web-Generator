                  {
                    "hintType": "barren",
                    "iterations": 4,
                    "starting": 4,
                    "saveToVar": "barrenHints",
                    "options": {
                      "validAreas": [
                        "alias:overworldZones",
                        "category.Northern_Desert",
                        "category.Southern_Desert"
                      ]
                    }
                  }
                ]
              }
            ]
          },
          {
            // Prioritizes hinting importance counts 1,2,3 with slight
            // preference for 1. Falls back to any count, but for S2 this is
            // basically guaranteed not to happen.
            "maxPicks": 1,
            "hintDef": [
              {
                "selectionType": "randomOrder",
                "hintDef": [
                  {
                    "hintType": "importanceCount",
                    "saveToVar": "firstLayerSpotFiller",
                    "weight": 0.4,
                    "options": {
                      "indicateImportant": false,
                      "allowedCounts": [1],
                      "validAreas": [
                        "Sacred Grove",
                        "Kakariko Gorge",
                        "Kakariko Village",
                        "Kakariko Graveyard",
                        "Lanayru Field",
                        "Beside Castle Town",
                        "Great Bridge of Hylia",
                        "Lanayru Spring",
                        "Zora's Domain",
                        "Gerudo Desert",
                        "Hyrule Castle"
                      ]
                    }
                  },
                  {
                    "hintType": "importanceCount",
                    "saveToVar": "firstLayerSpotFiller",
                    "weight": 0.3,
                    "options": {
                      "indicateImportant": false,
                      "allowedCounts": [2],
                      "validAreas": [
                        "Sacred Grove",
                        "Kakariko Gorge",
                        "Kakariko Village",
                        "Kakariko Graveyard",
                        "Lanayru Field",
                        "Beside Castle Town",
                        "Great Bridge of Hylia",
                        "Lanayru Spring",
                        "Zora's Domain",
                        "Gerudo Desert",
                        "Hyrule Castle"
                      ]
